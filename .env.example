########################################
# Kuroji API — Environment Variables
########################################

## === App Settings ===
PORT=3000                                # Port to run the server (default: 3000)
PUBLIC_URL=http://localhost:3000         # Public API URL (optional)

## === CORS ===
# Comma-separated list of allowed origins
# Example: https://example.com,https://app.example.com
# Use * to allow all origins
# Default = PUBLIC_URL
CORS=http://localhost:3000

## === Update Settings ===
ANIME_UPDATE_ENABLED=true            # Enable automatic anime updates
ANIME_REINDEXING_ENABLED=true        # Enable anime indexer updates

# Skips indexing animes with less than that number of popularity
# If you have database less than 500mb, recommended to set it to 7500 at least
ANIME_POPULARITY_THRESHOLD=1500

# Make it lower if you want it to index upcoming animes, usually announces dont get much popularity
ANIME_POPULARITY_THRESHOLD_UPCOMING=1500

# Delay between each index of release, in seconds
ANIME_PROCESSING_DELAY=5

## === External APIs ===
ANILIST=https://graphql.anilist.co
MYANIMELIST=https://myanimelist.net
SHIKIMORI=https://shikimori.io
KITSU=https://kitsu.app/api/edge
TMDB=https://api.themoviedb.org/3
TVDB=https://api4.thetvdb.com/v4
ZEROCHAN=https://www.zerochan.net

## === Providers ===
# Toggle individual data sources on/off
USE_MYANIMELIST=true
USE_SHIKIMORI=true
USE_KITSU=true
USE_TMDB=true
USE_TVDB=true
USE_ZEROCHAN=true

## === Zerochan ===
# Zerochan login credentials
ZEROCHAN_USER=kurojiq
ZEROCHAN_PASSWORD=j^V+$D>L79mE52.

## === API Keys ===
# External service keys (optional)
TMDB_API_KEY=
TVDB_API_KEY= # not required at all

## === Rate Limiting ===
# Doesnt work without caching*
RATE_LIMIT=0                             # Requests per window (0 = disabled)
RATE_LIMIT_TTL=60                        # Time window in seconds

## === Admin ===
# Optional key with full API access
ADMIN_KEY=

## === Strategy ===
# all_routes = all routes will require api key
# not_required = all routes do not require the api key
API_KEY_STRATEGY= # (default: not_required)

## === WHITELIST ===
# Routes that will not be affected by api key requirement
ROUTES_WHITELIST=/docs,/docs/openapi,/

## === BLACKLIST ===
# Routes that will be always affected by api key requirement
ROUTES_BLACKLIST=

## === Redis ===
CACHING_ENABLED=true                               # Enable Redis cache
REDIS_TTL=900                          # Cache TTL in seconds (default: 900)

# redis://[:password]@host:port/db
# Local w/o password:   redis://localhost:6379
# Local w/ password:    redis://:mypassword@localhost:6379
REDIS_URL=redis://localhost:6379

## === Database ===

# Number of database operations to process in a single batch.
# Higher values = fewer round trips, but bigger transactions.
# Warning: setting this too high can cause timeouts or lock contention.
TRANSACTION_BATCH=10

# PostgreSQL connection string:
# postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql://drizzle:postgres@localhost:5432/kuroji

## === Hostings ===

# If you use vercel, set this to true
VERCEL=false

# If you use free render, set this to true, this enables self polling so the service didnt go into inactive
RENDER=false

NODE_ENV=production
